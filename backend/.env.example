# ─── Barista CI — Backend Environment Variables Example ─────────────────────
# Copy this file to backend/.env and fill in your real API keys.
# NEVER commit the real .env to version control.

# ─── Core LLM ────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_MODEL=nomic-embed-text

# ─── Search APIs (set at least one) ──────────────────────────────────────────
TAVILY_API_KEY=
SERPER_API_KEY=
BING_SEARCH_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
SEARCH_PROVIDER=tavily
SEARCH_STRATEGY=parallel

# ─── Optional Flags ───────────────────────────────────────────────────────────
STRICT_STARTUP_VALIDATION=false
ENABLE_FUZZY_SCORING=false

# ─── CORS ────────────────────────────────────────────────────────────────────
# Add your production domain here when deploying to Railway
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── SQLite Checkpointer ─────────────────────────────────────────────────────
CHECKPOINTER_BACKEND=sqlite
CHECKPOINT_DB_PATH=/app/barista_checkpoints.sqlite

# ─── Optional Serper endpoint override ───────────────────────────────────────
SERPER_BASE_URL=https://google.serper.dev
